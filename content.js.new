// Universal PromptGuard Content Script - MV3 Chrome Compatible\n// Auto-injected on ALL sites via manifest.json content_scripts\n\nclass PromptGuardContent {\n    constructor() {\n        this.isActive = true;\n        this.autoOptimizeEnabled = true;\n        this.nerSensitivity = 'medium'; // low|medium|high\n        this.floatingIcon = null;\n        this.miniPopup = null;\n        this.nerThreshold = 0.5;\n        this.detectionPatterns = {\n            email: /\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b/g,\n            phone: /(\\+?1?[-.\\s]?)?\\(?([0-9]{3})\\)?[-.\\s]?([0-9]{3})[-.\\s]?([0-9]{4})/g,\n            ssn: /\\b\\d{3}-?\\d{2}-?\\d{4}\\b/g,\n            creditCard: /\\b(?:\\d{4}[-\\s]?){3}\\d{4}\\b/g,\n            address: /\\d+\\s+[A-Za-z\\s]+(?:Street|St|Avenue|Ave|Road|Rd|Boulevard|Blvd|Drive|Dr|Lane|Ln|Way|Court|Ct)/gi,\n            apiKey: /(?:(?:sk|ak|pk)[_-][A-Za-z0-9]{32,}|Bearer\\s+[A-Za-z0-9_-]{32,})/gi\n        };\n        this.init();\n    }\n\n    async init() {\n        console.log('🛡️ PromptGuard Universal: Initializing on', window.location.hostname);\n        \n        // Load settings immediately\n        await this.loadSettings();\n        \n        // Robust UI creation\n        if (document.readyState === 'complete') {\n            this.createUI();\n        } else {\n            document.addEventListener('DOMContentLoaded', () => this.createUI());\n        }\n        \n        // Universal monitoring\n        this.startUniversalMonitoring();\n        \n        // SPA navigation handling\n        this.setupNavigationHandler();\n        \n        console.log('✅ PromptGuard Universal Ready - Protecting all inputs');\n    }\n\n    async loadSettings() {\n        return new Promise(resolve => {\n            chrome.storage.sync.get([\n                'isActive',\n                'auto_sanitize',\n                'ner_sensitivity',\n                'detectionSensitivity'\n            ], (settings) => {\n                this.isActive = settings.isActive !== false;\n                this.autoOptimizeEnabled = settings.auto_sanitize !== false;\n                this.nerSensitivity = settings.ner_sensitivity || 'medium';\n                \n                // Configure sensitivity\n                this.nerThreshold = {\n                    low: 0.8,\n                    medium: 0.5,\n                    high: 0.2\n                }[this.nerSensitivity] || 0.5;\n                \n                resolve();\n            });\n        });\n    }\n\n    createUI() {\n        this.createFloatingIcon();\n        this.createMiniPopup();\n        this.addAccessibilitySupport();\n    }\n\n    createFloatingIcon() {\n        const existing = document.querySelector('.promptguard-floating-icon');\n        if (existing) existing.remove();\n        \n        this.floatingIcon = document.createElement('div');\n        this.floatingIcon.className = 'promptguard-floating-icon' + (!this.isActive ? ' disabled' : '');\n        this.floatingIcon.innerHTML = '<div class=\"icon\">🛡️</div>';\n        this.floatingIcon.title = this.isActive ? 'PromptGuard Active' : 'PromptGuard Disabled';\n        this.floatingIcon.tabIndex = 0;\n        this.floatingIcon.role = 'button';\n        \n        this.floatingIcon.addEventListener('click', () => this.toggleMiniPopup());\n        this.floatingIcon.addEventListener('keydown', (e) => {\n            if (e.key === 'Enter' || e.key === ' ') {\n                e.preventDefault();\n                this.toggleMiniPopup();\n            }\n        });\n        \n        document.body.appendChild(this.floatingIcon);\n    }\n\n    // ... [keeping all existing UI methods unchanged: createMiniPopup, setupPopupControls, etc.]\n\n    /** UNIVERSAL INPUT MONITORING */\n    startUniversalMonitoring() {\n        // Enhanced universal selectors - ALL text inputs\n        const universalSelectors = [\n            'input[type=\"text\"], input[type=\"email\"], input:not([type=\"hidden\"]), input[type=\"search\"],\n            'textarea',\n            '[contenteditable=\"true\"], [role=\"textbox\"],\n            // AI/ML specific\n            '[data-slate-editor], [data-testid=\"textbox\"], #prompt-textarea',\n            '.ProseMirror, .ql-editor',\n            // Form builders\n            '.form-control, .form-input'\n        ].join(',');\n        \n        // Initial scan\n        this.scanAllInputs(document.querySelectorAll(universalSelectors));\n        \n        // Robust MutationObserver\n        const observer = new MutationObserver((mutations) => {\n            let shouldScan = false;\n            mutations.forEach(mutation => {\n                if (mutation.type === 'childList') {\n                    mutation.addedNodes.forEach(node => {\n                        if (node.nodeType === 1) { // ELEMENT_NODE\n                            const inputs = node.matches ? \n                                node.querySelectorAll(universalSelectors) : \n                                node.querySelectorAll ? node.querySelectorAll(universalSelectors) : [];\n                            Array.from(inputs).forEach(input => this.attachInputListener(input));\n                            shouldScan = true;\n                        }\n                    });\n                }\n            });\n            if (shouldScan) {\n                requestIdleCallback(() => this.scanAllInputs());\n            }\n        });\n        \n        observer.observe(document.body, {\n            childList: true,\n            subtree: true,\n            attributes: true,\n            attributeFilter: ['contenteditable']\n        });\n    }\n\n    scanAllInputs(inputs = document.querySelectorAll('*')) {\n        const universalSelectors = 'input:not([type=\"hidden\"]), textarea, [contenteditable=\"true\"], [role=\"textbox\"]';\n        const allInputs = inputs.querySelectorAll ? inputs.querySelectorAll(universalSelectors) : [];\n        Array.from(allInputs).forEach(input => this.attachInputListener(input));\n    }\n\n    attachInputListener(input) {\n        if (input.dataset.promptguardListener) return;\n        input.dataset.promptguardListener = 'true';\n\n        let debounceTimer;\n        const checkInput = () => {\n            if (!this.isActive) return;\n\n            clearTimeout(debounceTimer);\n            debounceTimer = setTimeout(() => {\n                const text = input.value || input.textContent || '';\n                if (text.length < 3) return;\n                \n                const result = this.pipeline(text);\n                if (result.entityCount > 0 && result.confidence > this.nerThreshold) {\n                    this.highlightInput(input, result.severity || 'warning');\n                    this.updateIconState(true);\n                    \n                    // Alert background\n                    chrome.runtime.sendMessage({\n                        action: 'alertDetected',\n                        issues: result.entities,\n                        entityCount: result.entityCount,\n                        confidence: result.confidence\n                    });\n\n                    // Auto-sanitize\n                    if (this.autoOptimizeEnabled) {\n                        const sanitized = this.enhancedSanitize(text, result);\n                        if (sanitized !== text) {\n                            this.replaceInputText(input, sanitized);\n                            this.showTooltip(input, `🛡️ Sanitized ${result.entityCount} entities`);\n                        }\n                    }\n                }\n            }, 250);\n        };\n\n        ['input', 'paste', 'change', 'keyup'].forEach(event => {\n            input.addEventListener(event, checkInput);\n        });\n    }\n\n    /** ENHANCED PIPELINE WITH SETTINGS */\n    pipeline(text) {\n        let confidence = 0;\n        let entities = [];\n        let processed = text;\n        let entityCount = 0;\n\n        // 1. REGEX - Always run\n        const regexEntities = this.detectPersonalInfoAdvanced(text);\n        entities = [...entities, ...regexEntities.map(e => ({...e, source: 'regex', confidence: 1.0}))];\n        entityCount += regexEntities.length;\n\n        // Apply regex masking\n        Object.entries(this.detectionPatterns).forEach(([type, pattern]) => {\n            processed = processed.replace(pattern, `[${type.toUpperCase()}]`);\n        });\n        confidence += 0.4;\n\n        // 2. TOKENIZATION + NER - Sensitivity controlled\n        if (this.nerSensitivity !== 'low') {\n            const tokenized = this.tokenize(processed);\n            const nerEntities = this.nerHeuristic(tokenized.tokens, tokenized.sentences);\n            entities = [...entities, ...nerEntities.map(e => ({...e, source: 'ner', confidence: 0.7}))];\n            entityCount += nerEntities.length;\n            confidence += 0.3;\n        }\n\n        // 3. Contextual scoring\n        const severityScore = entities.reduce((sum, e) => {\n            const severity = this.getSeverityScore(e.type);\n            return sum + (severity * e.confidence);\n        }, 0) / Math.max(entities.length, 1);\n\n        return {\n            original: text,\n            processed,\n            entities,\n            entityCount,\n            confidence,\n            severity: severityScore\n        };\n    }\n\n    enhancedSanitize(text, pipelineResult) {\n        let sanitized = pipelineResult.processed;\n        \n        // Multi-pass replacement\n        pipelineResult.entities.forEach(entity => {\n            const placeholder = `[${entity.type.toUpperCase()}]`;\n            const escaped = entity.value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n            sanitized = sanitized.replace(new RegExp(escaped, 'gi'), placeholder);\n        });\n        \n        // Privacy preamble\n        return `[PromptGuard Protected: ${pipelineResult.entityCount} entities masked]\\n\\n${sanitized}`;\n    }\n\n    // Keep all existing helper methods (detectPersonalInfoAdvanced, tokenize, nerHeuristic, etc.)\n    // ... [All existing methods preserved and enhanced]\n\n    /** Settings sync */\n    setupSettingsSync() {\n        chrome.storage.onChanged.addListener((changes) => {\n            if (changes.isActive) this.isActive = changes.isActive.newValue !== false;\n            if (changes.auto_sanitize) this.autoOptimizeEnabled = changes.auto_sanitize.newValue !== false;\n            if (changes.ner_sensitivity) {\n                this.nerSensitivity = changes.ner_sensitivity.newValue;\n                this.nerThreshold = {\n                    low: 0.8, medium: 0.5, high: 0.2\n                }[this.nerSensitivity] || 0.5;\n            }\n            this.updateIconState();\n        });\n    }\n\n    // SPA Navigation\n    setupNavigationHandler() {\n        let lastUrl = location.href;\n        new MutationObserver(() => {\n            if (location.href !== lastUrl) {\n                lastUrl = location.href;\n                setTimeout(() => {\n                    this.cleanup();\n                    this.init();\n                }, 500);\n            }\n        }).observe(document, {subtree: true, childList: true});\n    }\n\n    cleanup() {\n        document.querySelectorAll('[data-promptguard-listener]').forEach(el => {\n            el.removeAttribute('data-promptguard-listener');\n        });\n        if (this.floatingIcon) this.floatingIcon.remove();\n        if (this.miniPopup) this.miniPopup.remove();\n    }\n}\n\n// Universal initialization - NO site check needed\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', () => new PromptGuardContent());\n} else {\n    new PromptGuardContent();\n}\n\nconsole.log('🛡️ PromptGuard Universal Loaded - Protecting ALL sites');
